    # Optional packages (uncomment to enable)
    # - resource: Microsoft.WinGet.DSC/WinGetPackage
    #   id: iTunes
    #   directives:
    #     description: Optional - Install iTunes
    #   settings:
    #     id: Apple.iTunes
    #     source: winget
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: sqlClrTypes2019
      directives:
        description: Dependency - SQL CLR Types 2019
      settings:
        id: Microsoft.CLRTypesSQLServer.2019
        source: winget
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: msodbcsql17
      directives:
        description: Dependency - Microsoft ODBC Driver 17 for SQL Server
      settings:
        id: Microsoft.msodbcsql.17
        source: winget
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: uiXaml27
      directives:
        description: Dependency - Microsoft UI XAML 2.7
      settings:
        id: Microsoft.UI.Xaml.2.7
        source: winget
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: uiXaml28
      directives:
        description: Dependency - Microsoft UI XAML 2.8
      settings:
        id: Microsoft.UI.Xaml.2.8
        source: winget
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: vcLibsDesktop14
      directives:
        description: Dependency - Microsoft VCLibs Desktop 14
      settings:
        id: Microsoft.VCLibs.Desktop.14
        source: winget
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: vcRedist2015x64
      directives:
        description: Dependency - Microsoft Visual C++ Redistributable 2015+ x64
      settings:
        id: Microsoft.VCRedist.2015+.x64
        source: winget
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: vcRedist2015x86
      directives:
        description: Dependency - Microsoft Visual C++ Redistributable 2015+ x86
      settings:
        id: Microsoft.VCRedist.2015+.x86
        source: winget
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: vstor
      directives:
        description: Dependency - Visual Studio Tools for Office Runtime
      settings:
        id: Microsoft.VSTOR
        source: winget
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: webDeploy
      directives:
        description: Dependency - Web Deploy
      settings:
        id: Microsoft.WebDeploy
        source: winget
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: windowsSdk26100
      directives:
        description: Dependency - Windows SDK 10.0.26100
      settings:
        id: Microsoft.WindowsSDK.10.0.26100
        source: winget

    - resource: PSDscResources/Registry
      id: enableDeveloperMode
      directives:
        description: Enable Developer Mode (non-default setting detected)
        securityContext: elevated
      settings:
        Ensure: Present
        Key: HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows\CurrentVersion\AppModelUnlock
        ValueName: AllowDevelopmentWithoutDevLicense
        ValueType: Dword
        ValueData: 1
    - resource: PSDscResources/Registry
      id: showFileExtensions
      directives:
        description: Show file extensions in Explorer (non-default setting detected)
      settings:
        Ensure: Present
        Key: HKEY_CURRENT_USER\Software\Microsoft\Windows\CurrentVersion\Explorer\Advanced
        ValueName: HideFileExt
        ValueType: Dword
        ValueData: 0
    - resource: PSDscResources/Registry
      id: darkThemeApps
      directives:
        description: Use dark app theme (non-default setting detected)
      settings:
        Ensure: Present
        Key: HKEY_CURRENT_USER\Software\Microsoft\Windows\CurrentVersion\Themes\Personalize
        ValueName: AppsUseLightTheme
        ValueType: Dword
        ValueData: 0
    - resource: PSDscResources/Registry
      id: darkThemeSystem
      directives:
        description: Use dark system theme (non-default setting detected)
      settings:
        Ensure: Present
        Key: HKEY_CURRENT_USER\Software\Microsoft\Windows\CurrentVersion\Themes\Personalize
        ValueName: SystemUsesLightTheme
        ValueType: Dword
        ValueData: 0
    - resource: PSDscResources/Script
      id: vpnScheduledTask
      directives:
        description: Create VPN scheduled task from XML
        securityContext: elevated
      settings:
        GetScript: |
          $taskName = 'VPN Connection on Logon and Unlock'
          $task = Get-ScheduledTask -TaskName $taskName -ErrorAction SilentlyContinue
          if ($null -ne $task) { return @{ Result = 'Present' } }
          return @{ Result = 'Absent' }
        TestScript: |
          $taskName = 'VPN Connection on Logon and Unlock'
          $task = Get-ScheduledTask -TaskName $taskName -ErrorAction SilentlyContinue
          return ($null -ne $task)
        SetScript: |
          $taskName = 'VPN Connection on Logon and Unlock'
          $xmlPath = Join-Path '${WinGetConfigRoot}' 'VPN Connection on Logon and Unlock.xml'
          $xmlContent = Get-Content -Path $xmlPath -Raw
          Register-ScheduledTask -TaskName $taskName -Xml $xmlContent -Force | Out-Null
  configurationVersion: 0.2.0