        securityContext: elevated
      settings:
        id: Microsoft.VisualStudio.Professional
        source: winget
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: webDeploy
      directives:
        description: Optional - Install Microsoft Web Deploy
      settings:
        id: Microsoft.WebDeploy
        source: winget
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: powerToys
      directives:
        description: Optional - Install PowerToys
      settings:
        id: Microsoft.PowerToys
        source: winget
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: nvmWindows
      directives:
