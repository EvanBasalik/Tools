      settings:
        id: Anaconda.Anaconda3
        source: winget
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: spotify
      directives:
        description: Optional - Install Spotify
      settings:
        id: SpotifyAB.SpotifyMusic
        source: winget
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: whatsapp
      directives:
