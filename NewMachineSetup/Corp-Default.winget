      settings:
        id: Quicken.Quicken
        source: winget
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: googleDrive
      directives:
        description: Install Google Drive
      settings:
        id: Google.GoogleDrive
        source: winget
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: zoom
      directives:
        description: Install Zoom
      settings:
        id: Zoom.Zoom
        source: winget
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: earTrumpet
      directives:
        description: Install EarTrumpet
      settings:
        id: 9NBLGGH516XP
        source: msstore
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: powershell
      directives:
        description: Install PowerShell
      settings:
        id: 9MZ1SNWT0N5D
        source: msstore
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: powerBi
      directives:
        description: Install Power BI
      settings:
        id: Microsoft.PowerBI
        source: winget
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: chrome
      directives:
        description: Install Google Chrome
      settings:
        id: Google.Chrome
        source: winget
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: git
      directives:
        description: Install Git
      settings:
        id: Git.Git
        source: winget
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: python
      directives:
        description: Install Python
      settings:
        id: Python.Python.3.13
        source: winget
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: visualStudioCommunity
      directives:
        description: Install latest Visual Studio Community
        securityContext: elevated
      settings:
        id: Microsoft.VisualStudio.Community
        source: winget
    - resource: Microsoft.VisualStudio.DSC/VSComponents
      id: visualStudioComponents
      dependsOn:
        - visualStudioCommunity
      directives:
        description: Install Visual Studio workloads from base.vsconfig
        securityContext: elevated
      settings:
        productId: Microsoft.VisualStudio.Product.Community
        channelId: VisualStudio.17.Release
        vsConfigFile: ${WinGetConfigRoot}\base.vsconfig
        includeRecommended: true
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: visualStudioCode
      directives:
        description: Install Visual Studio Code
      settings:
        id: XP9KHM4BK9FZ7Q
        source: msstore
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: wireshark
      directives:
        description: Install Wireshark
      settings:
        id: WiresharkFoundation.Wireshark
        source: winget
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: azureCli
      directives:
        description: Optional - Install Azure CLI
      settings:
        id: Microsoft.AzureCLI
        source: winget
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: microsoftOffice
      directives:
        description: Optional - Install Microsoft Office
      settings:
        id: Microsoft.Office
        source: winget
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: oneDrive
      directives:
        description: Optional - Install OneDrive
      settings:
        id: Microsoft.OneDrive
        source: winget
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: teams
      directives:
        description: Optional - Install Microsoft Teams
      settings:
        id: XP8BT8DW290MPQ
        source: msstore
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: windowsSubsystemForLinux
      directives:
        description: Optional - Install Windows Subsystem for Linux
      settings:
        id: Microsoft.WSL
        source: winget
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: plex
      directives:
        description: Optional - Install Plex
      settings:
        id: Plex.Plex
        source: winget
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: unityHub
      directives:
        description: Optional - Install Unity Hub
      settings:
        id: Unity.UnityHub
        source: winget
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: githubCli
      directives:
        description: Optional - Install GitHub CLI
      settings:
        id: GitHub.cli
        source: winget
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: remoteHelp
      directives:
